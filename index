  <script>
    /* ── SCROLL FADE-IN ───────────────────────────────── */
    const fadeEls = document.querySelectorAll('.fade-up');
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('visible'); observer.unobserve(e.target); } });
    }, { threshold: 0.12, rootMargin: '0px 0px -40px 0px' });
    fadeEls.forEach(el => observer.observe(el));

    /* ── DRAG-SCROLL CAROUSELS ────────────────────────── */
    function makeDraggable(track, dotsEl) {
      let isDown = false, startX, scrollLeft;

      track.addEventListener('mousedown', e => {
        isDown = true; track.classList.add('grabbing');
        startX = e.pageX - track.offsetLeft;
        scrollLeft = track.scrollLeft;
      });
      track.addEventListener('mouseleave', () => { isDown = false; track.classList.remove('grabbing'); });
      track.addEventListener('mouseup',    () => { isDown = false; track.classList.remove('grabbing'); });
      track.addEventListener('mousemove',  e => {
        if (!isDown) return;
        e.preventDefault();
        track.scrollLeft = scrollLeft - (e.pageX - track.offsetLeft - startX) * 1.4;
      });

      if (dotsEl) {
        const dots = dotsEl.querySelectorAll('span');
        const cards = track.children;
        track.addEventListener('scroll', () => {
          const idx = Math.round(track.scrollLeft / (cards[0]?.offsetWidth + 16 || 1));
          dots.forEach((d, i) => d.classList.toggle('active', i === idx));
        }, { passive: true });
        dots.forEach((d, i) => d.addEventListener('click', () => {
          track.scrollTo({ left: i * ((cards[0]?.offsetWidth || 300) + 16), behavior: 'smooth' });
        }));
      }
    }

