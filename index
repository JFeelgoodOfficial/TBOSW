            <div style="font-size:0.6rem;letter-spacing:0.22em;color:var(--gold);opacity:0.5;text-transform:uppercase;margin-bottom:20px;">~Revelation~</div>
            <p style="font-size:1rem;color:var(--white);line-height:1.9;font-style:italic;">"Let's step into the room of nothing.<br/><br/>Just us. No one else.<br/><br/>A problem presents itself.<br/><br/>A quiet pause, punctuated by a small, absent-minded sip of a drink, as I sense my gaze adrift, lost in thought."</p>
          </div>`,
        bgGrad: 'linear-gradient(165deg, #0c0e10, #12181e)'
      },
      {
        title: 'The Workbook — Reflection Prompt',
        caption: 'Open, guided space to write without limits.',
        bodyHTML: `
          <div style="font-family:var(--font-serif);max-width:340px;width:100%;text-align:left;">
            <div style="font-size:0.6rem;letter-spacing:0.22em;color:var(--gold);opacity:0.5;text-transform:uppercase;margin-bottom:16px;">Reflection Prompt</div>
            <p style="font-size:1rem;color:var(--white);line-height:1.9;">What mask do you wear in your daily life?</p>
            <p style="font-size:0.9rem;color:var(--muted);line-height:1.85;margin-top:12px;">Is there a version of yourself you are afraid to let go of?</p>
            <div style="margin-top:24px;border-top:1px solid var(--border);padding-top:18px;font-size:0.75rem;color:var(--muted);font-style:italic;">Use this space as your Imagination Room…</div>
            <div style="margin-top:14px;display:flex;flex-direction:column;gap:10px;">
              <span style="height:1px;background:var(--border);display:block;width:100%;"></span>
              <span style="height:1px;background:var(--border);display:block;width:100%;"></span>
              <span style="height:1px;background:var(--border);display:block;width:100%;"></span>
            </div>
          </div>`,
        bgGrad: 'linear-gradient(165deg, #100c0e, #1a1016)'
      }
    ];

    document.querySelectorAll('.sample-card').forEach(card => {
      const open = () => {
        const idx = parseInt(card.dataset.sample);
        const d = sampleData[idx];
        lightboxBody.style.background = d.bgGrad;
        lightboxBody.innerHTML = d.bodyHTML;
        lightboxFooter.innerHTML = `<h3>${d.title}</h3><p>${d.caption}</p>`;
        lightbox.classList.add('open');
        document.body.style.overflow = 'hidden';
        lightboxClose.focus();
      };
      card.addEventListener('click', open);
      card.addEventListener('keydown', e => { if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); open(); } });
    });

    const closeLightbox = () => {
      lightbox.classList.remove('open');
      document.body.style.overflow = '';
    };

    lightboxClose.addEventListener('click', closeLightbox);
    lightbox.addEventListener('click', e => { if (e.target === lightbox) closeLightbox(); });
    document.addEventListener('keydown', e => { if (e.key === 'Escape') closeLightbox(); });
  </script>
</body>
